rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global default deny safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    // 2. Sessions collection matches
    match /sessions/{sessionId} {
      allow create: if isSignedIn() 
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.id == sessionId;
        
      allow read, update, delete: if isSignedIn() 
        && resource.data.ownerId == request.auth.uid;

      // 3. Nested collections (auth/creds, keys, logs)
      match /auth/{document=**} {
        allow read, write: if isSignedIn() 
          && get(/databases/$(database)/documents/sessions/$(sessionId)).data.ownerId == request.auth.uid;
      }

      match /keys/{document=**} {
        allow read, write: if isSignedIn() 
          && get(/databases/$(database)/documents/sessions/$(sessionId)).data.ownerId == request.auth.uid;
      }

      match /logs/{document=**} {
        allow read, write: if isSignedIn() 
          && get(/databases/$(database)/documents/sessions/$(sessionId)).data.ownerId == request.auth.uid;
      }
    }
  }
}
