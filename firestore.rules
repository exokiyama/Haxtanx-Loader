rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global default deny safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    // 2. Sessions collection matches
    match /sessions/{sessionId} {
      allow create: if isSignedIn() 
        && request.resource.data.ownerId == request.auth.uid;
        
      // Allow read so client-side and server-side scanner on boot can get bot sessions
      allow read: if true;

      // Update and delete is strictly checked against the owner's UID
      allow update, delete: if isSignedIn() 
        && resource.data.ownerId == request.auth.uid;

      // 3. Nested collections (auth/creds, keys, logs)
      // Managed by Node server running unauthenticated via JS SDK, so we allow read/write.
      match /auth/{document=**} {
        allow read, write: if true;
      }

      match /keys/{document=**} {
        allow read, write: if true;
      }

      match /logs/{document=**} {
        allow read, write: if true;
      }
    }
  }
}
